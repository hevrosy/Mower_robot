<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="inertial_macros.xacro"/>

  <!-- Main robot dimensions -->
  <xacro:property name="robot_length" value="0.42"/>
  <xacro:property name="robot_width" value="0.55"/>
  <xacro:property name="robot_height" value="0.35"/>

  <!-- Chassis -->
  <xacro:property name="chassis_length" value="0.42"/>
  <xacro:property name="chassis_width" value="0.18"/>
  <xacro:property name="chassis_height" value="0.16"/>
  <xacro:property name="chassis_center_z" value="0.13"/>

  <!-- Tracks -->
  <xacro:property name="track_length" value="0.40"/>
  <xacro:property name="track_width" value="0.045"/>
  <xacro:property name="track_height" value="0.10"/>
  <xacro:property name="track_center_y" value="0.235"/>
  <xacro:property name="track_center_z" value="0.05"/>

  <!-- Drive wheel placeholders for ros2_control -->
  <xacro:property name="wheel_radius" value="0.01606"/>
  <xacro:property name="wheel_length" value="0.03"/>
  <xacro:property name="wheel_mass" value="0.20"/>
  <xacro:property name="wheel_y_offset" value="0.235"/>

  <!-- Small rear support placeholder -->
  <xacro:property name="caster_wheel_radius" value="0.01"/>
  <xacro:property name="caster_wheel_mass" value="0.01"/>
  <xacro:property name="caster_wheel_offset_x" value="-0.14"/>
  <xacro:property name="caster_wheel_offset_z" value="${caster_wheel_radius}"/>

  <material name="body_gray">
    <color rgba="0.7 0.7 0.7 1"/>
  </material>

  <material name="track_black">
    <color rgba="0.08 0.08 0.08 1"/>
  </material>

  <material name="sensor_black">
    <color rgba="0.05 0.05 0.05 1"/>
  </material>

  <material name="wheel_blue">
    <color rgba="0.2 0.2 1.0 1"/>
  </material>

  <material name="black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>

  <material name="red">
    <color rgba="1.0 0.0 0.0 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.3 1.0 1.0"/>
  </material>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.1 0.8 0.1 1.0"/>
  </material>

  <link name="base_link"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_footprint"/>

  <joint name="chassis_joint" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="chassis">
    <visual>
      <origin xyz="0 0 ${chassis_center_z}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
      <material name="body_gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 ${chassis_center_z}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>

    <xacro:inertial_box mass="8.0" x="${chassis_length}" y="${chassis_width}" z="${chassis_height}">
      <origin xyz="0 0 ${chassis_center_z}" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <!-- Visual track links -->
  <joint name="left_track_visual_joint" type="fixed">
    <parent link="chassis"/>
    <child link="left_track_visual"/>
    <origin xyz="0 ${track_center_y} ${track_center_z}" rpy="0 0 0"/>
  </joint>

  <link name="left_track_visual">
    <visual>
      <geometry>
        <box size="${track_length} ${track_width} ${track_height}"/>
      </geometry>
      <material name="track_black"/>
    </visual>
  </link>

  <joint name="right_track_visual_joint" type="fixed">
    <parent link="chassis"/>
    <child link="right_track_visual"/>
    <origin xyz="0 ${-track_center_y} ${track_center_z}" rpy="0 0 0"/>
  </joint>

  <link name="right_track_visual">
    <visual>
      <geometry>
        <box size="${track_length} ${track_width} ${track_height}"/>
      </geometry>
      <material name="track_black"/>
    </visual>
  </link>

  <!-- Drive wheels used by ros2_control / diff drive -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 ${wheel_y_offset} ${wheel_radius}" rpy="-${pi/2} 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="wheel_blue"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_length}" radius="${wheel_radius}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 ${-wheel_y_offset} ${wheel_radius}" rpy="${pi/2} 0 0"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
      </geometry>
      <material name="wheel_blue"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${wheel_radius}"/>
      </geometry>
    </collision>
    <xacro:inertial_cylinder mass="${wheel_mass}" length="${wheel_length}" radius="${wheel_radius}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_cylinder>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_wheel"/>
    <origin xyz="${caster_wheel_offset_x} 0 ${caster_wheel_offset_z}"/>
  </joint>

  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="${caster_wheel_radius}"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_wheel_radius}"/>
      </geometry>
    </collision>
    <xacro:inertial_sphere mass="${caster_wheel_mass}" radius="${caster_wheel_radius}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_sphere>
  </link>

</robot>